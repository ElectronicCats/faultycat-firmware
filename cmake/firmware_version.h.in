// DO NOT EDIT — edit /VERSION (or let the release workflow rewrite it
// from the git tag `vMAJOR.MINOR.PATCH.TWEAK`).
//
// Consumed by:
//   * usb/src/usb_descriptors.c   — derives bcdDevice + the version
//                                   string descriptor from these macros.
//   * services/host_proto/{emfi,crowbar}_proto.c — embeds the 4 version
//                                   bytes in the PING reply so the host
//                                   can validate firmware/CLI parity.

#pragma once

#define FW_VERSION_MAJOR  @PROJECT_VERSION_MAJOR@u
#define FW_VERSION_MINOR  @PROJECT_VERSION_MINOR@u
#define FW_VERSION_PATCH  @PROJECT_VERSION_PATCH@u
#define FW_VERSION_TWEAK  @PROJECT_VERSION_TWEAK@u

#define FW_VERSION_STR "@PROJECT_VERSION@"

// USB bcdDevice is a 16-bit BCD field — fits MAJOR.MINOR.PATCH but not
// TWEAK. Packed as 0xMMmp per the USB spec:
//   high byte = MAJOR encoded as BCD (tens nibble | units nibble)
//   low byte  = (MINOR << 4) | PATCH  (treated as raw nibbles, 0..15)
// Examples: 3.0.0.7 → 0x0300 ; 3.1.4.0 → 0x0314 ; 12.5.0.0 → 0x1250.
// Operators reading `lsusb -v` see the first three segments; the full
// 4-segment version is reachable via the PING reply or the
// "FaultyCat Version: X.Y.Z.W" USB string descriptor.
#define FW_VERSION_BCD                                                       \
    (uint16_t)(((FW_VERSION_MAJOR / 10u) << 12) |                            \
               ((FW_VERSION_MAJOR % 10u) << 8) |                             \
               ((FW_VERSION_MINOR & 0xFu) << 4) |                            \
               (FW_VERSION_PATCH & 0xFu))
